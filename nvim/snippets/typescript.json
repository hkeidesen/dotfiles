{
  "Arrow Function": {
    "prefix": "fn",
    "body": [
      "const ${1:functionName} = (${2:params}): ${3:ReturnType} => {",
      "\t${0:// function body}",
      "}"
    ],
    "description": "Typed arrow function"
  },
  "Async Arrow Function": {
    "prefix": "afn",
    "body": [
      "const ${1:functionName} = async (${2:params}): Promise<${3:ReturnType}> => {",
      "\t${0:// function body}",
      "}"
    ],
    "description": "Typed async arrow function"
  },
  "Interface": {
    "prefix": "interface",
    "body": [
      "interface ${1:InterfaceName} {",
      "\t${0:property: string}",
      "}"
    ],
    "description": "TypeScript interface"
  },
  "Type": {
    "prefix": "type",
    "body": "type ${1:TypeName} = ${0:string}",
    "description": "TypeScript type alias"
  },
  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:ClassName} {",
      "\tconstructor(${2:params}) {",
      "\t\t${0:// constructor body}",
      "\t}",
      "}"
    ],
    "description": "Class definition"
  },
  "Export": {
    "prefix": "exp",
    "body": "export { ${1:item} } from '${0:./path}'",
    "description": "Export statement"
  },
  "Import": {
    "prefix": "imp",
    "body": "import { ${1:item} } from '${0:module}'",
    "description": "Import statement"
  },
  "Default Import": {
    "prefix": "impd",
    "body": "import ${1:defaultExport} from '${0:module}'",
    "description": "Default import"
  }
}
